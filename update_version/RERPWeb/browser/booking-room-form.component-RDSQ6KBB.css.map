.text-danger {
  color: #ff4d4f;
}

.form-control-sm {
  height: 31px;
  padding: 0.25rem 0.5rem;
  font-size: 0.875rem;
  line-height: 1.5;
  border-radius: 0.2rem;
}

.modal-dialog-scrollable {
  max-width: 100%;
}

.modal-header {
  border-bottom: 1px solid #dee2e6;
}

.modal-header.bg-primary {
  background-color: #1890ff !important;
  border-bottom: 1px solid #1890ff;
}

.modal-header.bg-primary h6 {
  color: #fff !important;
}

.modal-header h6 {
  color: #000;
  text-transform: uppercase;
  font-weight: 600;
}

.modal-footer {
  background-color: #f5f5f5;
  border-top: 1px solid #d9d9d9;
}

.modal-footer.bg-whitesmoke {
  background-color: #f5f5f5 !important;
}

::ng-deep .ant-form-item-label > label {
  font-weight: 500;
}

::ng-deep .ant-modal-body {
  padding: 24px;
}

.btn-success {
  background-color: #52c41a;
  border-color: #52c41a;
  color: #fff;
}

.btn-success:hover {
  background-color: #73d13d;
  border-color: #73d13d;
  color: #fff;
}

.btn-danger {
  background-color: #ff4d4f;
  border-color: #ff4d4f;
  color: #fff;
}

.btn-danger:hover {
  background-color: #ff7875;
  border-color: #ff7875;
  color: #fff;
}

.btn-sm {
  padding: 0.25rem 0.5rem;
  font-size: 0.875rem;
  line-height: 1.5;
  border-radius: 0.2rem;
}
